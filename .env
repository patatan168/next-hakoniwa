NEXT_PUBLIC_TITLE=箱庭諸島
NEXT_PUBLIC_VERSION=0.0.0

NEXT_PUBLIC_ORIGIN_URL=http://localhost:3000/

# Passkey Settings
NEXT_PUBLIC_RP_NAME=箱庭諸島
NEXT_PUBLIC_RP_ID=localhost
NEXT_PUBLIC_MAX_PASSKEYS=5
# NOTE: ランダムな文字列を設定すること。変更するとフィンガープリントが無効化される
PASSKEY_FP_PEPPER=change-me-to-a-random-secret-string

# Turn Settings
NEXT_PUBLIC_TURN_TIMEZONE="Asia/Tokyo"
NEXT_PUBLIC_TURN_CRON="0 0,4,8,12,16,20 * * *"

# Login Bonus Settings
NEXT_PUBLIC_ENABLE_LOGIN_BONUS=true
NEXT_PUBLIC_LOGIN_BONUS_MONEY=200
NEXT_PUBLIC_LOGIN_BONUS_FOOD=2000

# PLAN Settings
NEXT_PUBLIC_PLAN_LENGTH=20

# MAP Settings
NEXT_PUBLIC_MAP_SIZE=12

# Unit Settings
NEXT_PUBLIC_UNIT_MONEY=億円
NEXT_PUBLIC_UNIT_FOOD=トン
NEXT_PUBLIC_UNIT_AREA=万坪

# Initial and Maximum Values
NEXT_PUBLIC_INIT_MONEY=1000
NEXT_PUBLIC_MAX_MONEY=9999

# Food Settings
NEXT_PUBLIC_INIT_FOOD=1000
NEXT_PUBLIC_MAX_FOOD=999900

# Lack Food Settings
NEXT_PUBLIC_LACK_FOOD_DESTROY_RATE=25

# Food Consumption Settings
NEXT_PUBLIC_EATEN_FOOD_PER_PEOPLE=0.2

# Excchange Rate Settings
NEXT_PUBLIC_FOOD_TO_MONEY_RATE=0.0008

# Earn Food Settings
NEXT_PUBLIC_EARN_FARM_PER_PEOPLE=1

# Earn Money Settings
NEXT_PUBLIC_EARN_FACTORY_PER_PEOPLE=0.001
NEXT_PUBLIC_EARN_MINING_PER_PEOPLE=0.001

# Forest Settings
NEXT_PUBLIC_FOREST_VALUE=5

# Earthquake Settings
NEXT_PUBLIC_EARTHQUAKE_RATE=0.5
NEXT_PUBLIC_EARTHQUAKE_DESTROY_RATE=25

# Tsunami Settings
NEXT_PUBLIC_TSUNAMI_RATE=1.5

# Typhoon Settings
NEXT_PUBLIC_TYPHOON_RATE=2

# Meteorite Settings
NEXT_PUBLIC_METEORITE_RATE=1.5
NEXT_PUBLIC_CONTINUOUS_METEORITE_RATE=50
NEXT_PUBLIC_HUGE_METEORITE_RATE=0.5

# Volcanic Eruption Settings
NEXT_PUBLIC_ERUPTION_RATE=1

# Fire Settings
NEXT_PUBLIC_FIRE_RATE=1

# FALL DOWN Settings
NEXT_PUBLIC_FALL_DOWN_RATE=3
NEXT_PUBLIC_FALL_DOWN_BORDER=9000

# Treasure Settings
NEXT_PUBLIC_BURIED_TREASURE_RATE=0.1

# Oil Settings
NEXT_PUBLIC_OIL_FIELD_RATE=1
NEXT_PUBLIC_OIL_EXHAUSTION_RATE=40
NEXT_PUBLIC_OIL_EARN=1000

# Monster Settings
NEXT_PUBLIC_MONSTER_RATE=0.03

# Village Appearance Settings
NEXT_PUBLIC_VILLAGE_APPEARANCE_RATE=20

# Growth Settings
NEXT_PUBLIC_PEOPLE_GROWTH_VILLAGE=10
NEXT_PUBLIC_PEOPLE_GROWTH_TOWN=10
NEXT_PUBLIC_PEOPLE_GROWTH_CITY=0

# Propagation Settings
NEXT_PUBLIC_PEOPLE_PROPAGANDA_VILLAGE=30
NEXT_PUBLIC_PEOPLE_PROPAGANDA_TOWN=30
NEXT_PUBLIC_PEOPLE_PROPAGANDA_CITY=3

# Loss Settings
NEXT_PUBLIC_PEOPLE_LOSS_FAMINE=3

# Authentication Settings
ISSUER=JOHN_DOE
REFRESH_TOKEN_EXPIRES_HOUR=720
ACCESS_TOKEN_EXPIRES_HOUR=1
LOGIN_FAIL_LIMIT=5
LOGIN_LOCK_MINUTE=10
MAX_SESSIONS=3