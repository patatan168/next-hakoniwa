  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "turn": "tsx ./src/db/turn.ts",
    "lint": "eslint 'src/**/*.{ts,tsx}' && npm run lint:style && npm run lint:type",
    "lint:style": "stylelint --ignore-path .gitignore 'src/**/*.(css|tsx)'",
    "lint:type": "tsc --noEmit --incremental false",
    "fmt": "prettier --write **/*.{css,scss,json,md,ts,tsx}",
    "fmt-check": "prettier --check **/*.{css,scss,json,md}",
    "ncu:upd": "npx -y npm-check-updates -u",
    "db:codegen": "tsx ./src/db/codegen.ts",
    "db:init": "tsx ./src/db/migrate.ts && npm run db:codegen",
    "db:migrate": "tsx ./src/db/migrate.ts && npm run db:codegen",
    "db:rollback": "tsx ./src/db/migrate.ts down",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "pentest": "./scripts/pentest.sh"
  },
